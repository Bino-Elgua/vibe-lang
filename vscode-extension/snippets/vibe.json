{
  "Function": {
    "prefix": "fn",
    "body": [
      "fn ${1:functionName}(${2:params}) -> ${3:ReturnType} {",
      "  ${4:// implementation}",
      "}"
    ],
    "description": "Function declaration"
  },
  "Struct": {
    "prefix": "struct",
    "body": [
      "struct ${1:StructName} {",
      "  ${2:field}: ${3:Type},",
      "}"
    ],
    "description": "Struct definition"
  },
  "Enum": {
    "prefix": "enum",
    "body": [
      "enum ${1:EnumName} {",
      "  ${2:Variant1},",
      "  ${2:Variant2},",
      "}"
    ],
    "description": "Enumeration type"
  },
  "If Statement": {
    "prefix": "if",
    "body": [
      "if ${1:condition} {",
      "  ${2:// true branch}",
      "} else {",
      "  ${3:// false branch}",
      "}"
    ],
    "description": "If-else conditional"
  },
  "For Loop": {
    "prefix": "for",
    "body": [
      "for ${1:item} in ${2:iterable} {",
      "  ${3:// loop body}",
      "}"
    ],
    "description": "For loop"
  },
  "While Loop": {
    "prefix": "while",
    "body": [
      "while ${1:condition} {",
      "  ${2:// loop body}",
      "}"
    ],
    "description": "While loop"
  },
  "Match": {
    "prefix": "match",
    "body": [
      "match ${1:value} {",
      "  ${2:pattern1} => ${3:result1},",
      "  ${4:pattern2} => ${5:result2},",
      "}"
    ],
    "description": "Pattern matching"
  },
  "Prompt": {
    "prefix": "%%",
    "body": [
      "fn ${1:functionName}() {",
      "  %% ${2:describe what you want the AI to do}",
      "}"
    ],
    "description": "AI prompt function"
  },
  "LLM Attribute": {
    "prefix": "#[llm",
    "body": [
      "#[llm(model=\"${1:claude}\", temperature=${2:0.7})]",
      "fn ${3:functionName}() {",
      "  ${4:// implementation}",
      "}"
    ],
    "description": "LLM configuration"
  },
  "Agent Attribute": {
    "prefix": "#[agent",
    "body": [
      "#[agent(tools=[${1:\"tool1\", \"tool2\"}}])]",
      "fn ${2:functionName}() {",
      "  ${3:// agent logic}",
      "}"
    ],
    "description": "Agent definition"
  },
  "Test": {
    "prefix": "#[test",
    "body": [
      "#[test]",
      "fn ${1:test_name}() {",
      "  assert!(${2:condition}, \"message\");",
      "}"
    ],
    "description": "Test function"
  }
}
