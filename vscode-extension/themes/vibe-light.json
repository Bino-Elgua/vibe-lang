{
  "name": "Vibe Light",
  "type": "light",
  "colors": {
    "editor.background": "#ffffff",
    "editor.foreground": "#333333",
    "editor.lineNumberForeground": "#999999",
    "editor.selectionBackground": "#add6ff",
    "editor.inactiveSelectionBackground": "#e5ebf1",
    "editorCursor.foreground": "#333333"
  },
  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment"],
      "settings": {
        "foreground": "#008000"
      }
    },
    {
      "name": "String",
      "scope": ["string"],
      "settings": {
        "foreground": "#a31515"
      }
    },
    {
      "name": "Number",
      "scope": ["constant.numeric"],
      "settings": {
        "foreground": "#098658"
      }
    },
    {
      "name": "Keyword",
      "scope": ["keyword"],
      "settings": {
        "foreground": "#0000ff"
      }
    },
    {
      "name": "AI Keyword",
      "scope": ["keyword.ai"],
      "settings": {
        "foreground": "#ff7f50"
      }
    },
    {
      "name": "Function",
      "scope": ["entity.name.function"],
      "settings": {
        "foreground": "#795e26"
      }
    },
    {
      "name": "Type",
      "scope": ["entity.name.type"],
      "settings": {
        "foreground": "#267f99"
      }
    },
    {
      "name": "Operator",
      "scope": ["keyword.operator"],
      "settings": {
        "foreground": "#333333"
      }
    }
  ]
}
