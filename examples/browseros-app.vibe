-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
-- DASHBOARD VIEW
-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

fn show_dashboard() {
  let total = len(tasks)
  let completed = len(tasks.filter(|t| t.completed))
  let pending = total - completed
  
  print("═══════════════════════════════════")
  print("📊 DASHBOARD")
  print("═══════════════════════════════════")
  print("")
  print(format("Total Tasks:    {}", total))
  print(format("Completed:      {}", completed))
  print(format("Pending:        {}", pending))
  print(format("Completion:     {}%", (completed / total) * 100))
  print("")
}

-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
-- SETTINGS VIEW
-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

fn show_settings() {
  print("═══════════════════════════════════")
  print("⚙️ SETTINGS")
  print("═══════════════════════════════════")
  print("")
  print(format("Theme:          {}", user_prefs.theme))
  print(format("Language:       {}", user_prefs.language))
  print(format("Notifications:  {}", user_prefs.notifications))
  print("")
}

-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
-- STATISTICS VIEW
-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

fn show_statistics() {
  let high_priority = len(tasks.filter(|t| t.priority == "high"))
  let medium_priority = len(tasks.filter(|t| t.priority == "medium"))
  let low_priority = len(tasks.filter(|t| t.priority == "low"))
  
  print("═══════════════════════════════════")
  print("📈 STATISTICS")
  print("═══════════════════════════════════")
  print("")
  print(format("High Priority:   {}", high_priority))
  print(format("Medium Priority: {}", medium_priority))
  print(format("Low Priority:    {}", low_priority))
  print("")
}

